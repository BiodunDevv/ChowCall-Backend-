# App
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
APP_NAME=ChowCall API
FRONTEND_BASE_URL=http://localhost:3000
BRAND_LOGO_URL=https://chowcall.ng/chowcall-logo.svg

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
MONGODB_DB_NAME=ChowCall

# Redis
REDIS_URL=redis://default:<password>@<host>:<port>
REDIS_PREFIX=ChowCall

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/docs

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Flutterwave
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# Maps
MAPS_PROVIDER=mapbox
MAPBOX_ACCESS_TOKEN=pk_or_sk_from_mapbox

# AI / Speech
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_MODEL_NAME=
AZURE_OPENAI_API_VERSION=2024-04-01-preview
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Messaging
BREVO_API_KEY=
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+10000000000
WHATSAPP_PROVIDER=disabled
SMS_PROVIDER=twilio

# Email via Brevo Transactional Email
EMAIL_PROVIDER=brevo
EMAIL_FROM=ChowCall <hello@chowcall.ng>
EMAIL_REPLY_TO=support@chowcall.ng

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Jobs
QUEUE_CONCURRENCY=5
PAYMENT_EXPIRY_MINUTES=15
